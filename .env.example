# ─────────────────────────────────────────────
# Squadly — variables d'environnement
# Copie ce fichier en `.env.local` et remplis les valeurs.
# ─────────────────────────────────────────────

# Supabase (auth + DB)
# Récupère ces clés sur https://supabase.com/dashboard → Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_anon_key_here
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key_here

# Anthropic (AI Brief Builder)
# https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=sk-ant-xxx

# Stripe Connect (escrow par jalons)
# https://dashboard.stripe.com/apikeys
STRIPE_SECRET_KEY=sk_test_xxx
STRIPE_WEBHOOK_SECRET=whsec_xxx
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_xxx

# Resend (emails transactionnels, optionnel — fallback FormSubmit actif sinon)
# https://resend.com/api-keys
RESEND_API_KEY=re_xxx
RESEND_FROM_EMAIL=Squadly <hello@squadly.fr>
RESEND_TEAM_EMAIL=hello@squadly.fr

# Adresse mail de fallback (utilisée si Resend pas configuré, via FormSubmit gratuit)
# Au premier message, FormSubmit envoie un mail de confirmation à activer.
FALLBACK_CONTACT_EMAIL=kirchs.samuel@gmail.com

# App
NEXT_PUBLIC_APP_URL=http://localhost:3000
